// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  username  String   @unique
  password  String
  nickname  String?
  dept      String?
  phone     String?
  firstName String?
  lastName  String?
  avatar    String?
  role      Role     @default(USER)
  status    Status   @default(ACTIVE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workflows Workflow[]
  approvals Approval[]
  expenses  Expense[]
  comments  Comment[]

  @@map("users")
}

model Workflow {
  id        String   @id @default(cuid())
  title     String
  description String?
  type      WorkflowType
  status    WorkflowStatus @default(DRAFT)
  
  createdBy String
  creator   User     @relation(fields: [createdBy], references: [id])
  
  steps     WorkflowStep[]
  approvals Approval[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("workflows")
}

model WorkflowStep {
  id          String   @id @default(cuid())
  workflowId  String
  workflow    Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  
  stepNumber  Int
  title       String
  description String?
  approverRole String
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([workflowId, stepNumber])
  @@map("workflow_steps")
}

model Expense {
  id          String   @id @default(cuid())
  title       String
  amount      Float
  currency    String   @default("CNY")
  category    String
  description String?
  
  submittedBy String
  submitter   User     @relation(fields: [submittedBy], references: [id])
  
  attachments String[] // URLs
  status      ExpenseStatus @default(PENDING)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  approvals   Approval[]
  comments    Comment[]

  @@map("expenses")
}

model Approval {
  id          String   @id @default(cuid())
  workflowId  String
  workflow    Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  
  expenseId   String?
  expense     Expense? @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  
  approvedBy  String
  approver    User     @relation(fields: [approvedBy], references: [id])
  
  status      ApprovalStatus
  comment     String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("approvals")
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  
  expenseId String
  expense   Expense  @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("comments")
}

model SystemRole {
  id        Int      @id @default(autoincrement())
  name      String
  key       String   @unique
  sort      Int      @default(0)
  status    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  roleMenus  SystemRoleMenu[]

  @@map("sys_roles")
}

model SystemMenu {
  id         Int      @id @default(autoincrement())
  name       String
  sort       Int      @default(0)
  permission String
  component  String
  status     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  roleMenus  SystemRoleMenu[]

  @@map("sys_menus")
}

model SystemRoleMenu {
  roleId    Int
  menuId    Int
  createdAt DateTime @default(now())

  role SystemRole @relation(fields: [roleId], references: [id], onDelete: Cascade)
  menu SystemMenu @relation(fields: [menuId], references: [id], onDelete: Cascade)

  @@id([roleId, menuId])
  @@map("sys_role_menus")
}

model SystemDept {
  id        Int      @id @default(autoincrement())
  name      String
  sort      Int      @default(0)
  status    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("sys_depts")
}

model SystemPost {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  name      String
  sort      Int      @default(0)
  status    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("sys_posts")
}

model SystemDict {
  id        Int      @id @default(autoincrement())
  name      String
  type      String
  remark    String?
  status    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("sys_dicts")
}

model SystemNotice {
  id        Int      @id @default(autoincrement())
  title     String
  type      String
  status    Boolean  @default(true)
  creator   String   @default("admin")
  content   String?
  isNew     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("sys_notices")
}

model NoticeRead {
  id        Int      @id @default(autoincrement())
  noticeId  Int
  userId    String
  isRead    Boolean  @default(true)
  readAt    DateTime @default(now())

  @@map("sys_notice_reads")
}

model Attachment {
  id         String   @id @default(cuid())
  ownerType  String
  ownerId    String
  url        String
  fileName   String?
  mime       String?
  size       Int?
  uploadedBy String?
  createdAt  DateTime @default(now())

  @@map("attachments")
}

model TravelRequest {
  id          String   @id @default(cuid())
  applicantId String
  dept        String?
  type        String
  status      String   @default("DRAFT")
  travelDetail Json?
  costCenter  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("travel_requests")
}

model AttendanceRecord {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime
  clockIn   DateTime?
  clockOut  DateTime?
  normalHours Float?
  otHours   Float?
  status    String?
  remark    String?
  createdAt DateTime @default(now())

  @@map("attendance_records")
}

model ReportSummary {
  id        String   @id @default(cuid())
  deptId    Int?
  month     String
  metricKey String
  metricVal Json
  createdAt DateTime @default(now())

  @@map("report_summaries")
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  action    String
  targetType String?
  targetId  String?
  before    Json?
  after     Json?
  createdAt DateTime @default(now())

  @@map("audit_logs")
}

enum Role {
  ADMIN
  MANAGER
  APPROVER
  USER
}

enum Status {
  ACTIVE
  INACTIVE
  DELETED
}

enum WorkflowType {
  EXPENSE_REIMBURSEMENT
  LEAVE_REQUEST
  PURCHASE_ORDER
  TRAVEL_REQUEST
}

enum WorkflowStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum ExpenseStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  PAID
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}
